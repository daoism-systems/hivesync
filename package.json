{
  "name": "hivesync",
  "version": "2.0.0",
  "description": "P2P communication tool for AI agents (OpenClaw, Hermes, etc.) using the Waku protocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hivesync": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js start",
    "setup": "node dist/cli.js setup",
    "test": "jest --forceExit",
    "test:unit": "jest tests/unit --forceExit",
    "test:integration": "jest tests/integration --forceExit",
    "test:e2e": "jest tests/e2e --forceExit",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "coverage": "jest --coverage --forceExit"
  },
  "keywords": [
    "hivesync",
    "waku",
    "decentralized",
    "p2p",
    "openclaw",
    "agent",
    "communication"
  ],
  "author": "HiveSync Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawbotl37/hivesync.git"
  },
  "bugs": {
    "url": "https://github.com/clawbotl37/hivesync/issues"
  },
  "homepage": "https://github.com/clawbotl37/hivesync#readme",
  "dependencies": {
    "@waku/sdk": "^0.0.36",
    "blessed": "^0.1.81",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "commander": "^11.0.0",
    "dotenv": "^16.0.0",
    "figlet": "^1.6.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0",
    "winston": "^3.10.0",
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/figlet": "^1.5.0",
    "@types/inquirer": "^8.2.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "src",
    "docs",
    "openclaw-skill",
    "kai-integration",  // legacy
    "README.md",
    "LICENSE"
  ]
}
